# Supabase — copy to .env (Project Settings → API)
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your-publishable-or-anon-key

# จำเป็นสำหรับหน้าจัดการผู้ใช้ (สร้าง user / เปลี่ยนรหัสผ่าน) — ห้ามใส่ใน frontend
NUXT_SUPABASE_SECRET_KEY=your-service-role-or-secret-key

# Legacy names still work if you prefer:
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
